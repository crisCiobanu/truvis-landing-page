# Truvis landing page — environment variable inventory
#
# This file is committed. It documents the exact variable NAMES the app
# expects at build time and runtime, without any values. Copy it to
# `.env` (which is git-ignored) and fill in real values for local dev,
# or provision matching keys in Cloudflare Pages env for preview and
# production. Every variable here is read through `src/lib/env.ts` —
# never via `process.env` / `import.meta.env` directly (see CONTRACT.md
# § Environment Variable Access).
#
# Populated by: Story 1.2 (initial inventory), Story 1.7 (this template).
# Downstream stories wire each variable's actual consumer.

# -----------------------------------------------------------------------
# Core site
# -----------------------------------------------------------------------
# Public absolute URL used for canonicals / Open Graph. Must be the
# production origin in prod, the preview deploy URL in preview, and
# http://localhost:4321 in local. Prefixed PUBLIC_ so Astro exposes it
# to client code.
PUBLIC_SITE_URL=

# Launch phase toggle. Flipping this env var + redeploying atomically
# switches the hero + footer CTA between waitlist (pre) and App Store
# (post) variants. See src/lib/launch-phase.ts. Values: pre | post
LAUNCH_PHASE=

# -----------------------------------------------------------------------
# Email service provider — Loops (Epic 3 / Story 3.1)
# -----------------------------------------------------------------------
# Server-side only. Never expose client-side.
LOOPS_API_KEY=
LOOPS_AUDIENCE_ID=

# -----------------------------------------------------------------------
# Anti-spam — Cloudflare Turnstile (Epic 3 / Story 3.2)
# -----------------------------------------------------------------------
# PUBLIC_ prefix for the site key because the client widget needs it.
# The secret key is server-only.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------
# Analytics — Plausible Cloud EU (Epic 6 / Story 6.5)
# -----------------------------------------------------------------------
# The domain registered with Plausible (e.g. truvis.app). Client-readable.
PUBLIC_PLAUSIBLE_DOMAIN=

# -----------------------------------------------------------------------
# Error tracking — Sentry EU (Epic 7 / Story 7.4)
# -----------------------------------------------------------------------
# Server + client DSN. PUBLIC_ prefix because the browser SDK needs it.
PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------
# Social — Story 4.5
# -----------------------------------------------------------------------
# TODO(epic-5): move social handles to siteContent collection
# Twitter/X handle for the "via" parameter in share URLs (omit &via= if empty).
PUBLIC_TRUVIS_TWITTER_HANDLE=

# -----------------------------------------------------------------------
# Cookie-consent feature flag (Epic 7 / Story 7.1)
# -----------------------------------------------------------------------
# Boolean string ("true" / "false"). When false (V1 default — because
# Plausible is cookieless) the consent widget is wired but inactive.
COOKIE_CONSENT_REQUIRED=false
