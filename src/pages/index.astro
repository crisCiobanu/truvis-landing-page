---
/**
 * Home page — landing-page composition (Stories 2.9, 3.5)
 *
 * This is the canonical landing-page composition for V1. Stories 2.1
 * through 2.8 built each Tier-2 section individually; Story 2.9
 * locked the final order and Story 3.5 wired the three EmailCaptureBlock
 * instances (hero, mid-page, footer) into the CTA slots.
 *
 * TODO(epic-5): wire real social URLs inside `<Footer>` (owned by
 * BaseLayout) from the `siteContent` collection once Epic 5 Story 5.4
 * ships. This file does not render `<Footer>` directly — it lives in
 * BaseLayout — but this comment is the grep target for the swap.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/sections/hero-section.astro';
import ProblemSection from '@/components/sections/problem-section.astro';
import InspectionStorySection from '@/components/sections/inspection-story-section.astro';
import SocialProofSection from '@/components/sections/social-proof-section.astro';
import BlogPreviewsSection from '@/components/sections/blog-previews-section.astro';
import FaqSection from '@/components/sections/faq-section.astro';
import FooterCtaSection from '@/components/sections/footer-cta-section.astro';
import EmailCaptureBlock from '@/components/forms/email-capture-block.astro';
import { t, type Locale } from '@/lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;
---

<BaseLayout
  title={t('landing.meta.title', locale)}
  description={t('landing.meta.description', locale)}
>
  <HeroSection>
    <div slot="cta" data-testid="hero-cta-slot">
      <EmailCaptureBlock variant="hero" signupSource="hero" />
    </div>
  </HeroSection>
  <ProblemSection />
  <InspectionStorySection />

  {
    /*
     * Mid-page CTA band — a thin interstitial between the dark-primary
     * inspection-story climax and the white social-proof section. Not
     * a reusable Tier-2 section (scoped to this page only). The
     * `<h2 class="sr-only">` satisfies the `<section aria-labelledby>`
     * a11y contract without adding a second visible heading to the
     * page's rhetorical structure.
     */
  }
  <section aria-labelledby="mid-cta-heading" class="bg-[var(--color-bg)]">
    <div class="mx-auto max-w-3xl px-4 py-12 text-center sm:px-6 lg:px-8">
      <h2 id="mid-cta-heading" class="sr-only">
        {t('landing.midCta.srHeading', locale)}
      </h2>
      <p
        class="font-display mb-6 text-[length:var(--text-lg)] font-medium text-[var(--color-primary)]"
      >
        {t('landing.midCta.lede', locale)}
      </p>
      <div data-testid="mid-cta-slot" class="inline-flex justify-center">
        <EmailCaptureBlock variant="inline" signupSource="mid" />
      </div>
    </div>
  </section>

  <SocialProofSection />
  <BlogPreviewsSection />
  <FaqSection />
  <FooterCtaSection>
    <div slot="cta" data-testid="footer-cta-slot">
      <EmailCaptureBlock variant="footer" signupSource="footer" />
    </div>
  </FooterCtaSection>
</BaseLayout>
