---
/**
 * Home page — transitional shell (Story 1.4 T10)
 *
 * Wraps the landing page in the new `BaseLayout` so the header, skip
 * link, footer and semantic landmarks are exercised. Deliberately NO
 * Truvis marketing content yet — Epic 2 builds the real hero /
 * problem / story-scroll / etc. sections.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Truvis — Smarter used-car inspections"
  description="Truvis is a used-car inspection app that helps you know exactly what you are buying. Join the waitlist for early access."
>
  <section class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6">
    <h1
      class="font-display text-[length:var(--text-hero)] font-bold leading-tight text-[var(--color-primary)]"
    >
      A smarter way to inspect used cars.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-muted)]">
      Truvis is coming soon. The full landing page — hero, inspection story
      scroll, social proof, waitlist — lands in Epic 2.
    </p>
  </section>
</BaseLayout>
