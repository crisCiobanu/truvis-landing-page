---
/**
 * Home page — Epic 2 final composition (Story 2.9)
 *
 * This is the canonical landing-page composition for V1. Stories 2.1
 * through 2.8 built each Tier-2 section individually; Story 2.9 is the
 * checkpoint that locks the final order, inserts the mid-page CTA
 * band between `<InspectionStorySection />` and `<SocialProofSection />`,
 * and closes the page with `<FooterCtaSection />`.
 *
 * Three CTA placeholder slots share an identical
 * `data-cta-slot="..."` / `data-testid="..."` convention so Epic 3
 * Story 3.5 can swap them all via find-and-replace of
 * `data-cta-slot="hero|mid|footer"`.
 *
 * TODO(epic-5): wire real social URLs inside `<Footer>` (owned by
 * BaseLayout) from the `siteContent` collection once Epic 5 Story 5.4
 * ships. This file does not render `<Footer>` directly — it lives in
 * BaseLayout — but this comment is the grep target for the swap.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/sections/hero-section.astro';
import ProblemSection from '@/components/sections/problem-section.astro';
import InspectionStorySection from '@/components/sections/inspection-story-section.astro';
import SocialProofSection from '@/components/sections/social-proof-section.astro';
import BlogPreviewsSection from '@/components/sections/blog-previews-section.astro';
import FaqSection from '@/components/sections/faq-section.astro';
import FooterCtaSection from '@/components/sections/footer-cta-section.astro';
import { t, type Locale } from '@/lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;
---

<BaseLayout
  title={t('landing.meta.title', locale)}
  description={t('landing.meta.description', locale)}
>
  <HeroSection />
  <ProblemSection />
  <InspectionStorySection />

  {
    /*
     * Mid-page CTA band — a thin interstitial between the dark-primary
     * inspection-story climax and the white social-proof section. Not
     * a reusable Tier-2 section (scoped to this page only); lives
     * inline here so Story 3.5 can grep-replace `data-cta-slot="mid"`
     * in one place. The `<h2 class="sr-only">` satisfies the
     * `<section aria-labelledby>` a11y contract without adding a
     * second visible heading to the page's rhetorical structure.
     */
  }
  <section aria-labelledby="mid-cta-heading" class="bg-[var(--color-bg)]">
    <div class="mx-auto max-w-3xl px-4 py-12 text-center sm:px-6 lg:px-8">
      <h2 id="mid-cta-heading" class="sr-only">
        {t('landing.midCta.srHeading', locale)}
      </h2>
      <p
        class="font-display mb-6 text-[length:var(--text-lg)] font-medium text-[var(--color-primary)]"
      >
        {t('landing.midCta.lede', locale)}
      </p>
      {
        /*
         * TODO(epic-3): <div data-cta-slot="mid" ...> wrapper is
         * replaced by <EmailCaptureBlock slot="cta" variant="mid" />
         * via find-and-replace of data-cta-slot="mid" (Story 3.5).
         */
      }
      <div
        data-cta-slot="mid"
        data-testid="mid-cta-slot"
        class="inline-flex justify-center"
      >
        <button
          type="button"
          disabled
          aria-disabled="true"
          class="inline-flex items-center rounded-md bg-[var(--color-teal)] px-6 py-3 font-semibold text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)] disabled:cursor-not-allowed disabled:opacity-70"
        >
          {t('landing.midCta.ctaPlaceholder', locale)}
          <span class="sr-only"> — coming soon, form wires in Epic 3</span>
        </button>
      </div>
    </div>
  </section>

  <SocialProofSection />
  <BlogPreviewsSection />
  <FaqSection />
  <FooterCtaSection />
</BaseLayout>
