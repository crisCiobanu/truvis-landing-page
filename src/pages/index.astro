---
/**
 * Home page — Epic 2 composition
 *
 * Story 2.1 lands the first real marketing section (`HeroSection`) and
 * replaces the transitional placeholder that Story 1.4 shipped. Later
 * stories in Epic 2 (2.2 – 2.9) will append sections below the hero.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/sections/hero-section.astro';
import ProblemSection from '@/components/sections/problem-section.astro';
import { t, type Locale } from '@/lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;
---

<BaseLayout
  title={t('landing.meta.title', locale)}
  description={t('landing.meta.description', locale)}
>
  <HeroSection />
  <ProblemSection />
</BaseLayout>
