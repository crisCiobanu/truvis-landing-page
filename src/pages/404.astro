---
/**
 * 404 — Page not found (Story 1.5 / FR56)
 *
 * Astro renders this file for any unmatched route, and Cloudflare Pages
 * serves it with an HTTP 404 status automatically when the file is named
 * `404.astro`. See README § Hosting for the 5xx counterpart.
 *
 * Constraints (per story 1.5 Dev Notes):
 *   - Reuses `BaseLayout` (Story 1.4) — no bespoke layout.
 *   - No JS / React islands — must render even if the bundle fails.
 *   - Brand voice: 70 % Inspector / 30 % Ally. Short, calm, direct.
 *   - Two CTAs back to `/` and `/blog` (FR56).
 *   - Hardcoded English strings — Story 1.6 wires i18n.
 *   - Marked `noindex` so search engines don't surface the page.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found · Truvis"
  description="We couldn't find that page on Truvis. Head back to the landing page or browse the blog."
>
  <meta slot="head" name="robots" content="noindex" />

  <section
    class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-4 py-24 text-center sm:px-6"
  >
    <p
      class="mb-4 font-mono text-sm font-semibold tracking-[0.2em] text-[var(--color-teal)] uppercase"
    >
      Error 404
    </p>
    <h1
      class="font-display text-[length:var(--text-hero)] leading-tight font-bold text-[var(--color-primary)]"
    >
      Page not found.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-muted)]">
      That road doesn't lead anywhere on Truvis. Let's get you back on a route
      that does.
    </p>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:gap-6">
      <a
        href="/"
        class="inline-flex min-h-11 items-center justify-center rounded-lg bg-[var(--color-teal)] px-6 py-3 text-base font-semibold text-white transition-colors duration-[var(--duration-base,250ms)] hover:bg-[var(--color-primary)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-amber)]"
      >
        Back to homepage
      </a>
      <a
        href="/blog"
        class="inline-flex min-h-11 items-center justify-center rounded-lg border-2 border-[var(--color-primary)] px-6 py-3 text-base font-semibold text-[var(--color-primary)] transition-colors duration-[var(--duration-base,250ms)] hover:bg-[var(--color-surface)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-amber)]"
      >
        Read the blog
      </a>
    </div>
  </section>
</BaseLayout>
