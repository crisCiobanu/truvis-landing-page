---
/**
 * 500 — Server error (Story 1.5 / FR56)
 *
 * Astro renders `500.astro` for uncaught errors in its own routes and
 * emits the file as `dist/500.html`. Cloudflare Pages does NOT auto-serve
 * a custom 5xx page, so the mapping is wired up once per environment from
 * the Cloudflare dashboard (Workers & Pages → Settings → Custom Pages →
 * `5xx Errors` → `/500.html`). See README § Hosting → "Branded error
 * pages" for the rationale (`public/_routes.json` controls Function
 * routing only, not error responses, and therefore cannot satisfy AC2).
 *
 * Constraints (same as 404.astro — Dev Notes of story 1.5):
 *   - Reuses `BaseLayout` (Story 1.4) — no bespoke layout.
 *   - No JS / React islands — must render even if the bundle fails.
 *   - Brand voice: calm Inspector with one Ally reassurance beat.
 *   - Two CTAs back to `/` and `/blog` (FR56).
 *   - Hardcoded English — Story 1.6 wires i18n.
 *   - `noindex` so search engines don't surface the page.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Something went wrong · Truvis"
  description="Truvis hit an unexpected error. Give it a moment and try again."
>
  <meta slot="head" name="robots" content="noindex" />

  <section
    class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-4 py-24 text-center sm:px-6"
  >
    <p
      class="mb-4 font-mono text-sm font-semibold tracking-[0.2em] text-[var(--color-primary)] uppercase"
    >
      Error 500
    </p>
    <h1
      class="font-display text-[length:var(--text-hero)] leading-tight font-bold text-[var(--color-primary)]"
    >
      Something went wrong on our end.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-muted)]">
      We're looking into it. Give it a minute and try again — or head somewhere
      that's working.
    </p>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:gap-6">
      <a
        href="/"
        class="inline-flex min-h-11 items-center justify-center rounded-lg bg-[var(--color-teal)] px-6 py-3 text-base font-semibold text-white transition-colors duration-[var(--duration-base,250ms)] hover:bg-[var(--color-primary)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-amber)]"
      >
        Back to homepage
      </a>
      <a
        href="/blog"
        class="inline-flex min-h-11 items-center justify-center rounded-lg border-2 border-[var(--color-primary)] px-6 py-3 text-base font-semibold text-[var(--color-primary)] transition-colors duration-[var(--duration-base,250ms)] hover:bg-[var(--color-surface)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-amber)]"
      >
        Read the blog
      </a>
    </div>
  </section>
</BaseLayout>
