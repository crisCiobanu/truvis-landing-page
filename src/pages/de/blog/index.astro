---
/**
 * German blog index — Story 4.3 (localised route)
 *
 * Thin shell duplicating the English blog index composition. Astro's
 * i18n routing sets `Astro.currentLocale` to "de" automatically, so
 * all `t()` calls resolve German strings (V1: byte-for-byte English
 * copies per FR52; real translations land in V1.2).
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionEyebrow from '@/components/sections/section-eyebrow.astro';
import BlogPreviewCard from '@/components/blog/blog-preview-card.astro';
import BlogCategoryFilter from '@/components/blog/blog-category-filter.astro';
import EmailCaptureBlock from '@/components/forms/email-capture-block.astro';
import BlogFilterScript from '@/components/blog/blog-filter-script.astro';
import { getAllBlogPosts } from '@/lib/content';
import { t, type Locale } from '@/lib/i18n';

const locale = (Astro.currentLocale ?? 'de') as Locale;
const posts = await getAllBlogPosts();
const categories = [...new Set(posts.map((p) => p.category))];
---

<BaseLayout
  title={t('blog.index.title', locale)}
  description={t('blog.index.description', locale)}
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <SectionEyebrow variant="light" eyebrow={t('blog.index.eyebrow', locale)} />
    <h1
      class="font-display mt-4 text-3xl font-bold text-[var(--color-primary)] sm:text-4xl lg:text-5xl"
    >
      {t('blog.index.headline', locale)}
    </h1>

    {
      posts.length > 0 ? (
        <>
          <div class="mt-8 mb-10">
            <BlogCategoryFilter categories={categories} locale={locale} />
          </div>

          <div
            id="blog-grid"
            class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3"
          >
            {posts.map((post, index) => (
              <div
                data-category={post.category}
                data-featured={String(post.featured)}
              >
                <BlogPreviewCard post={post} priority={index === 0} />
              </div>
            ))}
          </div>
        </>
      ) : (
        <div class="mx-auto mt-16 max-w-lg text-center">
          <h2 class="font-display text-2xl font-bold text-[var(--color-primary)]">
            {t('blog.index.emptyHeadline', locale)}
          </h2>
          <p class="mt-3 text-[var(--color-muted)]">
            {t('blog.index.emptySubheadline', locale)}
          </p>
          <div class="mt-8">
            <EmailCaptureBlock
              variant="inline"
              signupSource="blog-empty"
              client:visible
            />
          </div>
        </div>
      )
    }
  </section>
</BaseLayout>

<BlogFilterScript />
