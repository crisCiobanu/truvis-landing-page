---
/**
 * Text-expansion harness — Story 1.7 (AC4, NFR26, UX-DR31)
 *
 * Renders every shell component built so far with placeholder strings
 * padded to ~140 % of their natural English length. This is the
 * synthetic FR/DE stress test: if anything overflows, truncates, or
 * wraps ugly at any breakpoint, the shell is not i18n-safe and must
 * be fixed **before** real translations land in V1.2.
 *
 * Padding method: every string is suffixed with a bracketed filler so
 * the overall length is ~140 % of the original. We keep the suffix
 * visible on purpose — reviewers should SEE that this is a stress test
 * and immediately spot a component that can't cope.
 *
 * This page is excluded from production routing by Astro conventions
 * (`_demo/` is a private folder — files inside still compile in dev but
 * do not appear in production routing) and is additionally marked
 * `noindex, nofollow` for belt-and-braces search-engine exclusion.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionEyebrow from '@/components/sections/section-eyebrow.astro';
import HeroSection from '@/components/sections/hero-section.astro';
import ProblemSection from '@/components/sections/problem-section.astro';
import StatCard from '@/components/sections/stat-card.astro';
import TrustQuoteCard from '@/components/sections/trust-quote-card.astro';
import InspectionStorySection from '@/components/sections/inspection-story-section.astro';
import SocialProofSection from '@/components/sections/social-proof-section.astro';
import BlogPreviewsSection from '@/components/sections/blog-previews-section.astro';
import { Button } from '@/components/ui/button';

// 140% padded variants of every user-facing shell string.
// Real FR/DE copy tends to run 120-140% the length of English, so 140%
// is a conservative stress target (UX-DR31 / NFR26).
const padded = {
  heroHeadline:
    "Know exactly what you're buying before you buy it — guaranteed inspection peace of mind",
  ctaPrimary: 'Join the Truvis waiting list now',
  ctaSecondary: 'Read the inspection buyer guide',
  eyebrowLight: 'How Truvis inspects every single used car',
  eyebrowDark: 'Trusted by thousands of careful used-car buyers',
  sectionHeadingLight: 'How Truvis inspects your next used car, end to end',
  sectionHeadingDark:
    'Thousands of careful buyers already trust Truvis inspections',
  nav: {
    home: 'Home and landing page',
    blog: 'Inspection buying guides',
    faq: 'Frequently asked questions',
    about: 'About Truvis, our mission',
  },
  footerCopy:
    'Truvis — the smarter used-car inspection application. Know what you are really buying before you sign anything at all.',
  // StatCard / TrustQuoteCard padded strings (Story 2.3 AC9, ~140%)
  statValue: '€1,240 average',
  statLabel:
    'Average first-year repair cost on an uninspected private-party used car',
  statSource: 'placeholder industry benchmark for stress test',
  quoteBody:
    'A third of private-party used cars in Europe hide at least one defect worth more than €500 to repair, and most buyers never find out until the first service.',
  quoteAttribution:
    'European Automobile Association, 2024 European used-car market survey',
  quoteContext:
    'independent industry body reporting on private-party transactions',
};
---

<BaseLayout
  title="Text-expansion harness — Truvis (not indexed)"
  description="Synthetic 140% text-expansion stress test for Truvis shell components. Not indexed."
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-12 border-l-4 border-[var(--color-amber)] pl-4">
      <p
        class="font-mono text-xs font-semibold tracking-widest text-[var(--color-teal)] uppercase"
      >
        Story 1.7 · AC4 · NFR26
      </p>
      <h1
        class="font-display mt-2 text-3xl font-bold text-[var(--color-primary)]"
      >
        Text-expansion harness (140% padding)
      </h1>
      <p class="mt-3 max-w-2xl text-[var(--color-muted)]">
        Every shell component on this page is rendered with placeholder strings
        padded to approximately 140% of their natural English length. Real
        French and German copy runs 120–140% of English — if anything on this
        page overflows, truncates, or wraps ugly, the component is not i18n
        safe. Resize the viewport from 320px up to 1440px and confirm nothing
        breaks.
      </p>
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* Note on Header / Footer coverage                                    */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 rounded-lg border border-[var(--color-divider)] bg-[var(--color-surface-2)] p-4"
    >
      <p class="text-sm text-[var(--color-muted)]">
        <strong class="text-[var(--color-primary)]">Header + Footer:</strong>
        these are already rendered at the top and bottom of this page by
        <code>BaseLayout</code>. Manual QA: resize the viewport and confirm the
        nav links never overlap the logo on tablet, and the footer column
        headings (<code>Product</code>, <code>Blog</code>, <code>Legal</code>,
        <code>Follow</code>) stack cleanly on mobile. The real text in
        <code>header.astro</code> / <code>footer.astro</code> is short enough that
        a 140% pad still fits inside the existing tap targets.
      </p>
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* SectionEyebrow — light variant                                      */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 rounded-lg bg-[var(--color-bg)] p-8 ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="mb-4 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        SectionEyebrow · variant=light
      </p>
      <SectionEyebrow eyebrow={padded.eyebrowLight} variant="light">
        <span slot="heading">{padded.sectionHeadingLight}</span>
      </SectionEyebrow>
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* SectionEyebrow — dark variant                                       */}
    {/* ------------------------------------------------------------------ */}
    <div class="mb-12 rounded-lg bg-[var(--color-primary)] p-8">
      <p
        class="mb-4 font-mono text-xs tracking-widest text-[var(--color-amber)] uppercase"
      >
        SectionEyebrow · variant=dark
      </p>
      <SectionEyebrow eyebrow={padded.eyebrowDark} variant="dark">
        <span slot="heading">{padded.sectionHeadingDark}</span>
      </SectionEyebrow>
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* CTA button row (shadcn primitives)                                  */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 rounded-lg bg-[var(--color-surface)] p-8 ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="mb-4 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        Tier-1 Button · padded copy
      </p>
      <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center">
        <Button size="lg">{padded.ctaPrimary}</Button>
        <Button variant="outline" size="lg">{padded.ctaSecondary}</Button>
      </div>
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* Hero headline stress test                                           */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 rounded-lg bg-[var(--color-surface-3)] p-8 ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="mb-4 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        Hero headline · fluid clamp type
      </p>
      <h2
        class="font-display max-w-3xl text-[length:var(--text-hero)] leading-tight font-bold text-[var(--color-primary)]"
      >
        {padded.heroHeadline}
      </h2>
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* Nav-link row stress test                                            */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 rounded-lg bg-[var(--color-bg)] p-8 ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="mb-4 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        Nav links (padded) · desktop inline row
      </p>
      <nav aria-label="Padded nav preview">
        <ul class="flex flex-wrap items-center gap-2">
          {
            Object.values(padded.nav).map((label) => (
              <li>
                <a
                  href="#"
                  class="inline-flex h-11 min-w-11 items-center rounded-md px-4 text-sm font-medium text-[var(--color-primary)] transition-colors hover:bg-[var(--color-surface-3)] hover:text-[var(--color-teal)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)]"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* HeroSection (Story 2.1) — real component rendered in-place          */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 overflow-hidden rounded-lg ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-3 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        HeroSection · story 2.1 · 140% padded i18n strings (see note)
      </p>
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-2 text-xs text-[var(--color-muted)]"
      >
        The hero below renders its copy through <code>t('landing.hero.*')</code>
        against the live locale JSON. To stress-test with 140% padded strings, temporarily
        pad the <code>hero</code> values in
        <code>src/i18n/en/landing.json</code> and reload this page — the section must
        not clip, truncate, or collapse at 375px, 768px, or 1280px viewport widths.
      </p>
      <HeroSection />
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* ProblemSection (Story 2.2) — real component rendered in-place       */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 overflow-hidden rounded-lg ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-3 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        ProblemSection · story 2.2 · live i18n strings (see note)
      </p>
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-2 text-xs text-[var(--color-muted)]"
      >
        The section below renders real copy through <code
          >t('landing.problem.*')</code
        >
        against the live locale JSON, inside its `max-w-2xl` body-text column. To
        stress-test at 140% padding, temporarily pad the
        <code>problem</code> values in
        <code>src/i18n/en/landing.json</code> and reload — the section must not clip,
        truncate, or collapse at 375px, 768px, or 1280px viewport widths, and the
        background surface must transition cleanly from the hero above.
      </p>
      <ProblemSection />
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* StatCard (Story 2.3) — one instance, 140% padded props              */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 rounded-lg bg-[var(--color-surface)] p-8 ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="mb-4 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        StatCard · story 2.3 · 140% padded props
      </p>
      <div class="max-w-sm">
        <StatCard
          category="teal"
          value={padded.statValue}
          label={padded.statLabel}
          source={padded.statSource}
        />
      </div>
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* TrustQuoteCard (Story 2.3) — one instance, 140% padded props        */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 rounded-lg bg-[var(--color-surface)] p-8 ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="mb-4 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        TrustQuoteCard · story 2.3 · 140% padded props
      </p>
      <div class="max-w-2xl">
        <TrustQuoteCard
          quote={padded.quoteBody}
          attribution={padded.quoteAttribution}
          context={padded.quoteContext}
        />
      </div>
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* InspectionStorySection (Story 2.5) — real component rendered       */}
    {/* in-place with live i18n strings. Stress-test by temporarily        */}
    {/* padding `landing.inspectionStory.*` in en/landing.json and         */}
    {/* reloading — confirm no clipping at 375/768/1280px and that the     */}
    {/* climax scene's centred layout with severity-red accent border      */}
    {/* holds under 140% padding.                                          */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 overflow-hidden rounded-lg ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-3 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        InspectionStorySection · story 2.5 · live i18n strings (see note)
      </p>
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-2 text-xs text-[var(--color-muted)]"
      >
        The section below renders real copy through <code
          >t('landing.inspectionStory.*')</code
        >
        against the live locale JSON, with the Story 2.4 sticky-phone mechanism hydrated
        in-place. To stress-test at 140% padding, temporarily pad the <code
          >inspectionStory</code
        > values in
        <code>src/i18n/en/landing.json</code> and reload — confirm no clipping, no
        horizontal scroll, and that scene 5's climax layout (centred column, severity-red
        accent border) still holds at 375/768/1280px viewport widths.
      </p>
      <InspectionStorySection />
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* SocialProofSection (Story 2.6) — real component rendered in-place  */}
    {/* with live i18n strings. Stress-test by temporarily padding         */}
    {/* `landing.socialProof.*` in en/landing.json and reloading — confirm */}
    {/* no clipping at 375/768/1280px, the three-column stats grid         */}
    {/* collapses cleanly below 768px, and the quote card stays within     */}
    {/* max-w-3xl and wraps naturally.                                     */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 overflow-hidden rounded-lg ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-3 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        SocialProofSection · story 2.6 · live i18n strings (see note)
      </p>
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-2 text-xs text-[var(--color-muted)]"
      >
        The section below renders real copy through
        <code>t('landing.socialProof.*')</code>
        against the live locale JSON. To stress-test at 140% padding, temporarily
        pad the <code>socialProof</code> values in
        <code>src/i18n/en/landing.json</code> and reload — confirm the three-column
        stats grid collapses cleanly below 768px and the quote card wraps without
        overflow.
      </p>
      <SocialProofSection />
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* BlogPreviewsSection (Story 2.7) — real component, live i18n        */}
    {/* ------------------------------------------------------------------ */}
    <div
      class="mb-12 overflow-hidden rounded-lg ring-1 ring-[var(--color-divider)]"
    >
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-3 font-mono text-xs tracking-widest text-[var(--color-muted)] uppercase"
      >
        BlogPreviewsSection · story 2.7 · live i18n strings (see note)
      </p>
      <p
        class="border-b border-[var(--color-divider)] bg-[var(--color-surface-2)] px-4 py-2 text-xs text-[var(--color-muted)]"
      >
        The section below renders real copy through
        <code>t('landing.blogPreviews.*')</code>
        against the live locale JSON. To stress-test at 140% padding, temporarily
        pad the <code>blogPreviews</code> values in
        <code>src/i18n/en/landing.json</code> and reload — confirm the 1/2/3 column
        responsive grid reflows cleanly and the <code>line-clamp-2</code> excerpt
        truncates without clipping the card footer.
      </p>
      <BlogPreviewsSection />
    </div>

    {/* ------------------------------------------------------------------ */}
    {/* Footer tagline stress                                               */}
    {/* ------------------------------------------------------------------ */}
    <div class="mb-12 rounded-lg bg-[var(--color-primary)] p-8">
      <p
        class="mb-4 font-mono text-xs tracking-widest text-[var(--color-amber)] uppercase"
      >
        Footer tagline (dark surface)
      </p>
      <p class="max-w-xl text-base leading-relaxed text-white/90">
        {padded.footerCopy}
      </p>
    </div>
  </section>
</BaseLayout>
