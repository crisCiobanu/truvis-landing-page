---
/**
 * InspectionStoryScroll reviewer demo — Story 2.4 (AC10)
 *
 * Renders the Story 2.4 mechanism end-to-end with a single hard-coded
 * placeholder scene so reviewers can exercise the sticky-phone +
 * Intersection Observer + CSS crossfade pipeline before Story 2.5
 * ships the six real scene blocks.
 *
 * The page is under `src/pages/_demo/` — Astro excludes files inside
 * underscore-prefixed folders from production routing (`dist/`) and
 * we additionally ship a `noindex, nofollow` meta tag as belt-and-
 * braces search-engine exclusion (mirrors the pattern in
 * `src/pages/_demo/text-expansion.astro`).
 *
 * The placeholder scene's JSX children live in
 * `src/components/islands/inspection-story-placeholder-demo.tsx` — a
 * small React wrapper that constructs the `scenes` array and mounts
 * `<InspectionStoryScroll />` internally. This indirection exists
 * because `scenes[i].children: ReactNode` is not serialisable across
 * the Astro → island boundary for `client:visible` hydration; keeping
 * the wrapper in React-land lets the island API stay idiomatic.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import InspectionStoryPlaceholderDemo from '@/components/islands/inspection-story-placeholder-demo';
---

<BaseLayout
  title="InspectionStoryScroll demo — Truvis (not indexed)"
  description="Reviewer demo for the Story 2.4 sticky-phone InspectionStoryScroll mechanism. Not indexed."
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <section class="mx-auto max-w-6xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="mb-12 border-l-4 border-[var(--color-amber)] pl-4">
      <p
        class="font-mono text-xs font-semibold tracking-widest text-[var(--color-teal)] uppercase"
      >
        Story 2.4 · UX-DR12 / UX-DR14 / UX-DR15
      </p>
      <h1
        class="font-display mt-2 text-3xl font-bold text-[var(--color-primary)]"
      >
        InspectionStoryScroll — mechanism demo
      </h1>
      <p class="mt-3 max-w-2xl text-[var(--color-muted)]">
        Reviewer checklist: <strong>(1)</strong> scroll the placeholder scene into
        view and confirm the narrative slot fades in and stays visible after scrolling
        past; <strong>(2)</strong> resize the viewport below 768px and confirm the
        sticky phone disappears and the scene stacks inline with its own phone instance;
        <strong>(3)</strong> toggle devtools → Rendering → "Emulate CSS
        <code>prefers-reduced-motion: reduce</code>" and reload — the scene must
        render at its final state instantly with no fade;
        <strong>(4)</strong> Tab through the page and confirm no focus trap and no
        accidental tab stops on decorative elements. Because this story ships only
        one scene, the crossfade between scenes is not visible here — Story 2.5 supplies
        the six real scenes.
      </p>
    </div>

    <InspectionStoryPlaceholderDemo client:visible />
  </section>
</BaseLayout>
