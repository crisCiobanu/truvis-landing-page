---
/**
 * SectionEyebrow — reusable pattern (Story 1.4 AC4 / UX-DR11)
 *
 * Small pill above a section heading, used across landing page
 * sections for rhythm and scannability. Two variants:
 *
 *  - light: teal-slate filled pill, white text, primary heading.
 *           For use on the warm-white `bg` surface.
 *  - dark:  warm-amber outlined pill, white heading.
 *           For use on dark (primary-coloured) section backgrounds.
 *
 * Uses Tailwind utilities + brand CSS custom properties — no bespoke CSS.
 */
interface Props {
  eyebrow: string;
  variant?: 'light' | 'dark';
  class?: string;
}

const { eyebrow, variant = 'light', class: className = '' } = Astro.props;

const pillClasses =
  variant === 'light'
    ? 'bg-[var(--color-teal)] text-white'
    : 'border border-[var(--color-amber)] text-[var(--color-amber)]';

const headingClasses =
  variant === 'light' ? 'text-[var(--color-primary)]' : 'text-white';
---

<div class:list={['flex flex-col items-start gap-4', className]}>
  <span
    class:list={[
      'inline-flex items-center rounded-full px-4 py-1 text-xs font-semibold tracking-widest uppercase',
      pillClasses,
    ]}
  >
    {eyebrow}
  </span>
  <div class:list={['font-display text-2xl font-bold', headingClasses]}>
    <slot name="heading" />
  </div>
</div>
