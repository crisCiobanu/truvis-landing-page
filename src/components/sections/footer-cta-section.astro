---
/**
 * FooterCtaSection — Story 2.9 (UX-DR3, UX-DR9, FR7, AR23)
 *
 * Tier-2 Astro composite: the dark `#2E4057` bookend closing the
 * landing page with one last "Join the waitlist" moment. Sits on the
 * dark-primary slot of the Epic-2 colour rhythm (white FAQ → dark
 * primary footer CTA → BaseLayout's `<Footer>`). Uses the narrower
 * `max-w-3xl` container and `text-center` for rhetorical emphasis —
 * deliberate editorial variances from the Epic-2 default
 * `max-w-6xl` / left-aligned sections.
 *
 * V1 ships the disabled "Join the waitlist" placeholder as the default
 * <slot name="cta"> fallback. Epic 3 Story 3.5 replaces it with
 * <EmailCaptureBlock slot="cta" variant="footer" /> via a find-and-
 * replace of data-cta-slot="footer".
 */
import SectionEyebrow from '@/components/sections/section-eyebrow.astro';
import { t, type Locale } from '@/lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;
---

<section aria-labelledby="footer-cta-heading" class="bg-[var(--color-primary)]">
  <div
    class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6 lg:px-8 lg:py-28"
  >
    <div class="flex flex-col items-center gap-6">
      <SectionEyebrow
        variant="dark"
        eyebrow={t('landing.footerCta.eyebrow', locale)}
      />
      <h2
        id="footer-cta-heading"
        class="font-display text-[length:var(--text-2xl)] leading-tight font-bold text-white"
      >
        {t('landing.footerCta.headline', locale)}
      </h2>
      <p class="max-w-2xl text-[length:var(--text-lg)] text-white/80">
        {t('landing.footerCta.subheadline', locale)}
      </p>

      {
        /*
         * TODO(epic-3): <slot name="cta"> is replaced by
         * <EmailCaptureBlock slot="cta" variant="footer" /> via a
         * find-and-replace of data-cta-slot="footer" (Story 3.5).
         */
      }
      <div class="mt-2 inline-flex justify-center">
        <slot name="cta">
          <div data-cta-slot="footer" data-testid="footer-cta-slot">
            <button
              type="button"
              disabled
              aria-disabled="true"
              class="inline-flex items-center rounded-md bg-[var(--color-teal)] px-6 py-3 font-semibold text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)] disabled:cursor-not-allowed disabled:opacity-70"
            >
              {t('landing.footerCta.ctaPlaceholder', locale)}
              <span class="sr-only"> — coming soon, form wires in Epic 3</span>
            </button>
          </div>
        </slot>
      </div>
    </div>
  </div>
</section>
