---
/**
 * BlogPreviewsSection — Story 2.7 → Story 4.7 (UX-DR7, FR6, AR23)
 *
 * Tier-2 pure-Astro composite sitting on the warm-grey
 * `--color-surface` slot of the Epic-2 colour rhythm (between the
 * white social proof and the white FAQ). Renders up to three real
 * BlogPreviewCard composites fed by lib/content.ts at build time.
 * Zero `client:*`, zero JavaScript.
 */
import SectionEyebrow from '@/components/sections/section-eyebrow.astro';
import BlogPreviewCard from '@/components/blog/blog-preview-card.astro';
import { getFeaturedBlogPosts, getAllBlogPosts } from '@/lib/content';
import { t, type Locale } from '@/lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;

let posts = await getFeaturedBlogPosts(3);
if (posts.length < 3) {
  const allPosts = await getAllBlogPosts();
  posts = allPosts.slice(0, 3);
}
---

<section
  aria-labelledby="blog-previews-heading"
  class="bg-[var(--color-surface)]"
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="flex max-w-2xl flex-col items-start gap-4">
      <SectionEyebrow
        variant="light"
        eyebrow={t('landing.blogPreviews.eyebrow', locale)}
      />
      <h2
        id="blog-previews-heading"
        class="font-display text-[length:var(--text-2xl)] leading-tight font-bold text-[var(--color-primary)]"
      >
        {t('landing.blogPreviews.headline', locale)}
      </h2>
    </div>

    <div
      class="mt-10 grid gap-6 sm:grid-cols-2 lg:mt-12 lg:grid-cols-3 lg:gap-8"
    >
      {posts.map((post) => (
        <BlogPreviewCard post={post} />
      ))}
    </div>
  </div>
</section>
