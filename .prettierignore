# Prettier ignore — Truvis landing page
#
# Keep this list tight: anything NOT ignored here is enforced by the
# CI `prettier --check .` gate (see .github/workflows/ci.yml).

# Build output
dist/
.astro/
.lighthouseci/

# Raw passthrough assets (favicons, robots.txt, OG images, etc.)
# — per CLAUDE.md these are never hand-formatted and may include
# binary or minified files that prettier can't parse.
public/

# Node / tooling caches
node_modules/
coverage/

# Vendored BMad skill payloads — not our code, not hand-edited
_bmad/
# BMad planning + implementation artefacts are authored/edited directly
# and formatted by hand (long tables, YAML front matter). Prettier
# reflows tables and breaks readability, so exclude them.
_bmad-output/

# Immutable Lighthouse baseline reports (Story 1.1 reference artefacts)
lighthouse/baseline/

# Package manifests — npm owns the formatting
package-lock.json

# dotenv templates — prettier has no parser for KEY=value files
.env.example

# Human-edited project docs and design artefacts
CLAUDE.md
truvis-home-screen-refined.html

# Devcontainer JSON supports comments — prettier can't parse JSONC
.devcontainer/devcontainer.json
